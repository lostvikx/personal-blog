---
pagination:
  data: collections
  size: 1
  alias: tag
permalink: "/tag/{{ tag }}/"
eleventyExcludeFromCollections: true
layout: tag.njk
title: Tagged Posts
---

<section>
    <h1>Posts tagged: #{{ tag }}</h1>
    <p>{{ tagDescriptions[tag] }}</p>
    <div class="blog-posts">
        {% for post in collections[tag] | reverse %}
        <div title="{{ post.data.description }}">
            <time>{{ post.data.date | dateStamp }}</time>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
        </div>
        {% endfor %}
    </div>
</section>
